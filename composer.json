{
    "name": "camelot/api-importer",
    "type": "symfony-bundle",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-pcntl": "*",
        "doctrine/doctrine-bundle": "^2.10",
        "doctrine/orm": "^2.15",
        "league/csv": "^9.9",
        "symfony/console": "^6.3"
    },
    "require-dev": {
        "camelot/coding-style": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.17",
        "justinrainbow/json-schema": "^5.2",
        "phpunit/phpunit": "^10.2"
    },
    "autoload": {
        "psr-4": {
            "Camelot\\ApiImporter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Camelot\\ApiImporter\\Tests\\": "tests/"
        }
    },
    "scripts": {
    }
}
